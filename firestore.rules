// Firestore security rules for the WB Quiz Bot leaderboard.
//
// Paste this into: Firebase Console → your project → Firestore Database →
// Rules tab → replace everything → Publish.
//
// HOW TO READ THIS: there is no Firebase Authentication in this project —
// index.html trusts whatever Telegram's WebApp SDK reports as the current
// user (initDataUnsafe.user) and writes with that identity directly from
// the student's browser. These rules stop obviously-malformed writes (wrong
// types, impossible scores, huge strings) but they can't cryptographically
// prove someone is who they say they are — that would need a small server
// function to verify Telegram's signed initData, which this project
// deliberately doesn't have (see DEPLOYMENT_GUIDE.md for the trade-off).
// For a friendly study-group leaderboard this is a reasonable line to draw;
// tighten it yourself if that trust model doesn't fit your use case.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // One doc per (quiz, student) — written once when a student finishes a
    // quiz. Never updated or deleted from the client, so a reload can't
    // change an already-recorded result.
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if request.resource.data.score is int
                    && request.resource.data.total is int
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= request.resource.data.total
                    && request.resource.data.total <= 50
                    && request.resource.data.name is string
                    && request.resource.data.name.size() <= 100
                    && request.resource.data.userId is string;
      allow update, delete: if false;
    }

    // One doc per student, holding running totals — this is what
    // dashboard.html reads for the Top 20.
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.resource.data.totalCorrect is number
                   && request.resource.data.totalQuestions is number
                   && request.resource.data.totalCorrect >= 0
                   && request.resource.data.totalQuestions >= 0
                   && request.resource.data.name is string
                   && request.resource.data.name.size() <= 100
                   && request.resource.data.userId is string
                   && request.resource.data.userId == userId;
    }
  }
}
